{
  "name": "wire-team-bot",
  "version": "0.1.0",
  "private": true,
  "main": "dist/app/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app/main.js",
    "dev": "ts-node src/app/main.ts",
    "cli": "node dist/app/cli.js",
    "test:e2e": "npx tsx tests/e2e/runner.ts",
    "simulate": "npx tsx tests/simulation/simulate.ts",
    "simulate:review": "npx tsx tests/simulation/review.ts",
    "lint": "eslint src tests --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "sdk:setup": "cd wire-apps-js-sdk && npm install && npm run build:setup && npm run build",
    "postinstall": "npm run sdk:setup"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "chrono-node": "^2.9.0",
    "dotenv": "^16.4.5",
    "prisma": "^6.0.0",
    "reflect-metadata": "^0.1.13",
    "wire-apps-js-sdk": "file:./wire-apps-js-sdk"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "*",
    "@typescript-eslint/parser": "*",
    "eslint": "*",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
