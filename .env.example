# ── Wire bot account ──────────────────────────────────────────────────────────
WIRE_SDK_USER_EMAIL=bot@your-wire-domain.com
WIRE_SDK_USER_PASSWORD=your-bot-password
WIRE_SDK_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
WIRE_SDK_USER_DOMAIN=your-wire-domain.com
WIRE_SDK_API_HOST=https://prod-nginz-https.wire.com
WIRE_SDK_CRYPTO_PASSWORD=a-strong-passphrase-for-local-crypto-store

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://wirebot:wirebot@localhost:5432/wire_team_bot

# ── LLM (all inference through one endpoint) ──────────────────────────────────
# Point at a local Ollama instance to keep all message content on-premises.
# Any OpenAI-compatible endpoint works (Ollama, vLLM, cloud API, etc.).
JEEVES_LLM_BASE_URL=http://localhost:11434/v1
JEEVES_LLM_API_KEY=

# Model slots — override only what differs from the defaults in config.ts
# JEEVES_MODEL_CLASSIFY=qwen3-2507:4b
# JEEVES_MODEL_EXTRACT=qwen3-2507:30b-a3b
# JEEVES_MODEL_EMBED=qwen3-embedding:4b
# JEEVES_MODEL_SUMMARISE=qwen3-2507:30b-a3b
# JEEVES_MODEL_QUERY_ANALYSE=granite4-tiny-h:7b
# JEEVES_MODEL_RESPOND=qwen3-2507:30b-a3b
# JEEVES_MODEL_COMPLEX=qwen3-next:80b

# Embedding vector dimensions — must match JEEVES_MODEL_EMBED output.
# qwen3-embedding:4b outputs 2560 dims. Change this if you use a different model.
JEEVES_EMBED_DIMS=2560

# ── Application ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
# MESSAGE_BUFFER_SIZE=50
# SECRET_MODE_INACTIVITY_MS=1800000
